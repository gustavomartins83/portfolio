---
interface Props {
  whiteNav?: boolean
}
const { whiteNav = false } = Astro.props

const links = [
  { label: 'Trabalhos', href: '#trabalhos' },
  { label: 'Sobre', href: '#sobre' },
  { label: 'Processo', href: '#processo' },
  { label: 'Contato', href: '#contato' },
]
---

<header id="header" class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300${whiteNav ? ' bg-white border-b border-neutral-100' : ''}`}>
  <nav class="max-w-[1600px] mx-auto px-6 h-[var(--header-height)] flex items-center justify-between">
    <a href={import.meta.env.BASE_URL} class="flex items-center">
      <img
        src="https://gustavocamposdesign.com/wp-content/uploads/2020/05/logo_site-1.png"
        alt="GC Design"
        class="h-10 w-auto"
      />
    </a>
    <ul class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class="text-sm text-neutral-500 hover:text-neutral-900 transition-colors relative after:absolute after:bottom-[-2px] after:left-0 after:h-px after:w-0 after:bg-[#0891B2] after:transition-all after:duration-300 hover:after:w-full"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="#contato"
      class="hidden md:inline-flex text-sm font-medium px-5 py-2 bg-[#0891B2] text-white rounded-full hover:bg-[#0670A0] transition-colors"
    >
      Vamos conversar
    </a>
    <button id="menu-toggle" class="md:hidden p-2 text-neutral-600" aria-label="Menu">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </nav>
  <div id="mobile-menu" class="hidden md:hidden border-t border-neutral-100 bg-white">
    <ul class="max-w-[1600px] mx-auto px-6 py-4 flex flex-col gap-4">
      {links.map(link => (
        <li>
          <a href={link.href} class="text-sm text-neutral-700 block py-1">{link.label}</a>
        </li>
      ))}
      <li>
        <a href="#contato" class="text-sm font-medium text-[#0891B2]">Vamos conversar →</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('header')
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-white/90', 'backdrop-blur-sm', 'border-b', 'border-neutral-100')
    } else {
      header?.classList.remove('bg-white/90', 'backdrop-blur-sm', 'border-b', 'border-neutral-100')
    }
  })

  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden')
  })
</script>
