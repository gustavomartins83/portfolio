---
import Layout from '../layouts/Layout.astro'
import ContatoFooter from '../components/ContatoFooter.astro'

const displayTextStyles = [
  { label: 'Display XL', name: 'Display/display-xl', node: '1606:31851', size: '72px', weight: '700', lh: '72px', sample: 'Oliveira Trust' },
  { label: 'Display LG', name: 'Display/display-lg', node: '1606:31846', size: '60px', weight: '700', lh: '60px', sample: 'Oliveira Trust' },
  { label: 'Display MD', name: 'Display/display-md', node: '1606:31841', size: '48px', weight: '700', lh: '48px', sample: 'Oliveira Trust' },
  { label: 'Display SM', name: 'Display/display-sm', node: '1606:31836', size: '36px', weight: '700', lh: '40px', sample: 'Oliveira Trust' },
]

const titleTextStyles = [
  { label: 'Title H1 Bold', name: 'Title/Bold/title-h1-bold', node: '1606:31831', size: '32px', weight: '700', lh: '40px', sample: 'Oliveira Trust' },
  { label: 'Title H2 Bold', name: 'Title/Bold/title-h2-bold', node: '1606:31826', size: '24px', weight: '700', lh: '32px', sample: 'Oliveira Trust' },
  { label: 'Title H3 Bold', name: 'Title/Bold/title-h3-bold', node: '1606:31821', size: '20px', weight: '700', lh: '28px', sample: 'Oliveira Trust' },
  { label: 'Title H4 Bold', name: 'Title/Bold/title-h4-bold', node: '1606:31816', size: '18px', weight: '700', lh: '24px', sample: 'Oliveira Trust' },
  { label: 'Title H5 Bold', name: 'Title/Bold/title-h5-bold', node: '415:5157', size: '16px', weight: '700', lh: '20px', sample: 'Oliveira Trust' },
]

const bodyTextStyles = [
  { label: 'Body LG Regular', name: 'Body/Regular/body-lg-regular', node: '328:11125', size: '18px', weight: '400', lh: '24px', sample: 'Design systems constroem consistencia entre produto, time e codigo.' },
  { label: 'Body MD Regular', name: 'Body/Regular/body-md-regular', node: '1606:31809', size: '16px', weight: '400', lh: '20px', sample: 'Design systems constroem consistencia entre produto, time e codigo.' },
  { label: 'Body SM Regular', name: 'Body/Regular/body-sm-regular', node: '1606:31804', size: '14px', weight: '400', lh: '20px', sample: 'Design systems constroem consistencia entre produto, time e codigo.' },
]

const captionTextStyles = [
  { label: 'Caption LG Medium', name: 'Caption/Medium/caption-lg-medium', node: '1606:31805', size: '14px', weight: '600', lh: '16px', sample: 'Token aplicado a rotulos e apoios visuais.' },
  { label: 'Caption MD Medium', name: 'Caption/Medium/caption-md-medium', node: '1606:31800', size: '12px', weight: '600', lh: '16px', sample: 'Token aplicado a rotulos e apoios visuais.' },
  { label: 'Caption SM Medium', name: 'Caption/Medium/caption-sm-medium', node: '1797:3740', size: '10px', weight: '600', lh: '12px', sample: 'Token aplicado a rotulos e apoios visuais.' },
]

const textStyleGroups = [
  { group: 'Display', count: 4, range: 'display-sm -> display-xl' },
  { group: 'Title/Regular', count: 5, range: 'title-h5-regular -> title-h1-regular' },
  { group: 'Title/Medium', count: 5, range: 'title-h5-medium -> title-h1-medium' },
  { group: 'Title/Bold', count: 5, range: 'title-h5-bold -> title-h1-bold' },
  { group: 'Body/Regular', count: 3, range: 'body-sm-regular -> body-lg-regular' },
  { group: 'Body/Medium', count: 3, range: 'body-sm-medium -> body-lg-medium' },
  { group: 'Body/Bold', count: 3, range: 'body-sm-bold -> body-lg-bold' },
  { group: 'Caption/Regular', count: 3, range: 'caption-sm-regular -> caption-lg-regular' },
  { group: 'Caption/Medium', count: 3, range: 'caption-sm-medium -> caption-lg-medium' },
  { group: 'Caption/Bold', count: 3, range: 'caption-sm-bold -> caption-lg-bold' },
]
---

<Layout whiteNav={true}>

  <!-- Hero do Projeto -->
  <section class="pt-32 pb-20" style="background: linear-gradient(135deg, #280000 0%, #7A0000 50%, #D40000 100%);">
    <div class="max-w-[1600px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-end">
        <div>
          <img src={`${import.meta.env.BASE_URL}ot-logo.svg`} class="h-6 mb-6 brightness-0 invert" alt="Oliveira Trust" />
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.0] tracking-tight mb-6">
            Design System
          </h1>
          <p class="text-white/70 text-lg leading-relaxed max-w-md">
            Sistema de design escalável para ecossistema fintech — tokens primitivos baseados na escala do Tailwind CSS, semântica própria, modo claro e escuro, e biblioteca de componentes integrada ao fluxo de desenvolvimento.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-4">
          {[
            { label: 'Papel', valor: 'Lead Designer' },
            { label: 'Base primitiva', valor: 'Tailwind CSS' },
            { label: 'Plataforma', valor: 'Web · Mobile' },
            { label: 'Ferramenta', valor: 'Figma' },
            { label: 'Tokens', valor: '400+' },
            { label: 'Componentes', valor: '80+' },
          ].map(m => (
            <div class="p-3 rounded-lg" style="background:rgba(255,255,255,0.12); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.2)">
              <p class="text-[10px] font-bold tracking-widest uppercase text-white/50 mb-1">{m.label}</p>
              <p class="text-white font-semibold text-sm">{m.valor}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Cover -->
  <div style="background: linear-gradient(180deg, #D40000 0%, #280000 100%);">
    <div class="max-w-[1600px] mx-auto px-6 py-12">
      <div class="aspect-[16/5] rounded-2xl overflow-hidden relative flex items-center justify-center" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12)">
        <!-- Grid of squares with varying opacity -->
        <div class="absolute inset-0 grid grid-cols-10 grid-rows-4 gap-2 p-6 opacity-20">
          {Array.from({length: 40}).map((_, i) => (
            <div class="rounded-lg bg-white" style={`opacity:${0.2 + (i % 7) * 0.12}`}></div>
          ))}
        </div>
        <div class="relative text-center z-10">
          <p class="text-[10px] font-bold tracking-widest uppercase text-white/60 mb-3">Design System · Oliveira Trust</p>
          <p class="text-white/25 text-8xl font-bold tracking-tighter">OT.DS</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Contexto -->
  <section class="py-24 bg-white">
    <div class="max-w-[1600px] mx-auto px-6">
      <div class="grid md:grid-cols-[1fr_2fr] gap-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase text-[#D40000] mb-3">Contexto</p>
          <h2 class="text-3xl font-bold text-neutral-900 leading-tight">O problema</h2>
        </div>
        <div class="space-y-5 text-neutral-500 text-[15px] leading-relaxed">
          <p>A Oliveira Trust, uma das principais empresas de serviços fiduciários do Brasil, operava com múltiplos produtos digitais sem consistência visual entre si. Cada produto tinha sua própria paleta, tipografia e padrões de componentes — resultando em retrabalho constante, handoffs inconsistentes e experiências fragmentadas para o usuário final.</p>
          <p>O desafio era construir um Design System do zero que fosse ao mesmo tempo <strong class="text-neutral-700">flexível o suficiente</strong> para atender múltiplos produtos e <strong class="text-neutral-700">restritivo o suficiente</strong> para garantir coesão — com suporte nativo a modo claro e escuro desde o primeiro token.</p>
          <p>A decisão estratégica foi adotar a <strong class="text-neutral-700">escala de valores do Tailwind CSS</strong> como base dos tokens primitivos — aproveitando uma nomenclatura já familiar para os times de front-end e garantindo compatibilidade direta entre o Figma e o código. Sobre essa base, criamos a camada semântica própria da Oliveira Trust, desacoplando os valores brutos da intenção de uso.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Acessibilidade -->
  <section class="py-24 bg-white">
    <div class="max-w-[1600px] mx-auto px-6">
      <div class="grid md:grid-cols-[1fr_2fr] gap-16 mb-16">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase text-[#D40000] mb-3">Acessibilidade</p>
          <h2 class="text-3xl font-bold text-neutral-900 leading-tight">Projetado para todos</h2>
        </div>
        <p class="text-neutral-500 text-[15px] leading-relaxed self-end">
          Acessibilidade não foi um requisito adicionado ao final — foi um princípio de fundação. Cada decisão de token, cor e estado foi avaliada contra as diretrizes WCAG 2.1, garantindo que os produtos construídos sobre o sistema sejam utilizáveis por qualquer pessoa.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <!-- Contraste -->
        <div class="rounded-2xl border border-[#EAECF0] p-8">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-6" style="background:#FDEEF0">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="8" stroke="#D40000" stroke-width="1.5"/>
              <path d="M10 2a8 8 0 0 1 0 16V2z" fill="#D40000"/>
            </svg>
          </div>
          <h3 class="text-base font-bold text-neutral-900 mb-2">Contraste verificado</h3>
          <p class="text-sm text-neutral-500 leading-relaxed mb-6">Todos os pares de cor texto/fundo foram validados contra WCAG 2.1. Tokens semânticos como <code class="text-[12px] font-mono bg-neutral-100 px-1 rounded">color-text-default</code> e <code class="text-[12px] font-mono bg-neutral-100 px-1 rounded">color-surface-level-0</code> garantem conformidade automática em qualquer tema.</p>
          <div class="space-y-2">
            {[
              { token: 'text-default',             color: '#2F3033', surface: '#F9FAFB', ratio: '14.1:1', badge: 'AAA' },
              { token: 'text-soft',                 color: '#707077', surface: '#F9FAFB', ratio: '5.1:1',  badge: 'AA'  },
              { token: 'text-color-action-brand',   color: '#D40000', surface: '#F9FAFB', ratio: '5.9:1',  badge: 'AA'  },
              { token: 'text-color-action-primary', color: '#006EEF', surface: '#F9FAFB', ratio: '4.6:1',  badge: 'AA'  },
            ].map(c => (
              <div class="flex items-center justify-between rounded-lg px-3 py-2" style={`background:${c.surface}; border:1px solid ${c.surface === '#1B1B1F' ? '#2F3033' : '#EAECF0'}`}>
                <div class="flex items-center gap-2 min-w-0">
                  <span class="shrink-0 w-3 h-3 rounded-full border border-black/10" style={`background:${c.color}`}></span>
                  <span class="text-[10px] font-mono truncate" style={`color:${c.color}`}>{c.token}</span>
                </div>
                <div class="flex items-center gap-2 shrink-0 ml-2">
                  <span class="text-[10px] font-semibold" style={`color:${c.color}`}>{c.ratio}</span>
                  <span class="text-[9px] font-bold px-1.5 py-0.5 rounded" style={`background:${c.badge === 'AAA' ? '#006D31' : '#006EEF'}; color:white`}>{c.badge}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Tokens semânticos -->
        <div class="rounded-2xl border border-[#EAECF0] p-8">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-6" style="background:#EDF5FF">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 10h12M4 6h8M4 14h6" stroke="#006EEF" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="text-base font-bold text-neutral-900 mb-2">Tokens por intenção</h3>
          <p class="text-sm text-neutral-500 leading-relaxed mb-6">A camada semântica desacopla valor de intenção. Componentes consomem <code class="text-[12px] font-mono bg-neutral-100 px-1 rounded">color-text-soft</code> — nunca <code class="text-[12px] font-mono bg-neutral-100 px-1 rounded">#707077</code> diretamente — garantindo que alterações de tema não quebrem contraste nem semântica.</p>
          <div class="space-y-2">
            {[
              { token: 'color-text-default',    role: 'Conteúdo principal'  },
              { token: 'color-text-soft',        role: 'Suporte e metadados' },
              { token: 'color-text-disabled',    role: 'Estados inativos'    },
              { token: 'color-surface-level-0',  role: 'Fundo base'          },
              { token: 'color-border-default',   role: 'Separadores'         },
            ].map(t => (
              <div class="flex items-center justify-between rounded-lg px-3 py-2" style="background:#F9FAFB">
                <code class="text-[10px] font-mono text-[#006EEF]">{t.token}</code>
                <span class="text-[11px] text-neutral-400 shrink-0">{t.role}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Estados acessíveis -->
        <div class="rounded-2xl border border-[#EAECF0] p-8">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center mb-6" style="background:#E6FAEF">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M5 10l3.5 3.5L15 7" stroke="#006D31" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="text-base font-bold text-neutral-900 mb-2">Estados multicanal</h3>
          <p class="text-sm text-neutral-500 leading-relaxed mb-6">Erros, alertas e confirmações nunca dependem só de cor. Cada estado combina cor + ícone + texto auxiliar, garantindo legibilidade para usuários com daltonismo ou baixa visão.</p>
          <div class="space-y-2.5">
            {[
              { label: 'Campo com erro',    icon: '!', bg: '#FDEEF0', border: '#CC2442', color: '#CC2442', msg: 'CPF inválido'         },
              { label: 'Campo com sucesso', icon: '✓', bg: '#E6FAEF', border: '#00A74E', color: '#006D31', msg: 'Verificado'           },
              { label: 'Foco de teclado',  icon: '◎', bg: '#EDF5FF', border: '#006EEF', color: '#006EEF', msg: 'focus-ring 3px offset'},
            ].map(s => (
              <div class="rounded-lg border px-3 py-2.5 flex items-center gap-3" style={`background:${s.bg}; border-color:${s.border}`}>
                <span class="text-sm font-bold shrink-0" style={`color:${s.color}`}>{s.icon}</span>
                <div>
                  <p class="text-[11px] font-semibold" style={`color:${s.color}`}>{s.label}</p>
                  <p class="text-[10px]" style={`color:${s.color}; opacity:0.75`}>{s.msg}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Arquitetura de Tokens -->
  <section class="py-24 bg-neutral-50">
    <div class="max-w-[1600px] mx-auto px-6">

      <div class="mb-16">
        <p class="text-xs font-bold tracking-widest uppercase text-[#D40000] mb-3">Fundação</p>
        <h2 class="text-4xl font-bold text-neutral-900 leading-tight mb-4">Arquitetura de tokens</h2>
        <p class="text-neutral-500 max-w-xl text-[15px] leading-relaxed">
          Os tokens primitivos espelham a escala do Tailwind CSS — paletas de cores, espaçamentos, tipografia e radii com a mesma nomenclatura usada no código. Sobre essa base, tokens semânticos atribuem intenção e garantem consistência entre temas.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 mb-8">

        <!-- Primitivos -->
        <div class="bg-white rounded-2xl border border-[#EAECF0] p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg bg-neutral-900 flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5" stroke="white" stroke-width="1.2"/><circle cx="7" cy="7" r="2" fill="white"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold tracking-widest uppercase text-neutral-400">Nível 1</p>
              <h3 class="font-bold text-neutral-900">Tokens Primitivos</h3>
            </div>
          </div>
          <p class="text-sm text-neutral-500 leading-relaxed mb-6">Espelham a escala do <strong class="text-neutral-700">Tailwind CSS</strong> — paletas, espaçamentos, radii e tipografia com a mesma nomenclatura do código. Não são consumidos diretamente pelos componentes.</p>
          <div class="grid grid-cols-1 gap-x-4">
            {[
              [
                { name: 'colors/brand/500',      value: '#D40000', type: 'color' },
                { name: 'colors/brand/400',      value: '#FF5540', type: 'color' },
                { name: 'colors/brand/100',      value: '#FFDAD4', type: 'color' },
                { name: 'colors/brand/50',       value: '#FFF0ED', type: 'color' },
                { name: 'colors/brand/950',      value: '#280000', type: 'color' },
                { name: 'colors/primary/500',    value: '#006EEF', type: 'color' },
                { name: 'colors/primary/400',    value: '#4A9DFF', type: 'color' },
                { name: 'colors/primary/100',    value: '#D8ECFF', type: 'color' },
                { name: 'colors/primary/50',     value: '#EDF5FF', type: 'color' },
                { name: 'colors/primary/900',    value: '#001A41', type: 'color' },
                { name: 'colors/red/500',        value: '#E22849', type: 'color' },
                { name: 'colors/red/50',         value: '#FDEEF0', type: 'color' },
                { name: 'colors/green/700',      value: '#006D31', type: 'color' },
                { name: 'colors/neutral/950',    value: '#1B1B1F', type: 'color' },
                { name: 'colors/neutral/900',    value: '#2F3033', type: 'color' },
              ],
            ].map(col => (
              <div class="space-y-1.5">
                {col.map(t => (
                  <div class="flex items-center justify-between py-1.5 border-b border-neutral-50 last:border-0">
                    <code class="text-[10px] text-neutral-500 font-mono truncate mr-2">{t.name}</code>
                    <div class="flex items-center gap-1.5 shrink-0">
                      {t.type === 'color' && (
                        <div class="w-3.5 h-3.5 rounded-full border border-neutral-200 shrink-0" style={`background:${t.value}`}></div>
                      )}
                      <code class="text-[10px] text-neutral-400 font-mono">{t.value}</code>
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

        <!-- Semânticos -->
        <div class="rounded-2xl p-8 shadow-sm" style="background:#1B1B1F">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 rounded-lg bg-[#006EEF] flex items-center justify-center">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M7 2l5 5-5 5" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold tracking-widest uppercase text-neutral-500">Nível 2</p>
              <h3 class="font-bold text-white">Tokens Semânticos</h3>
            </div>
          </div>
          <p class="text-sm text-neutral-400 leading-relaxed mb-6">Referenciam primitivos e carregam intenção de uso. São esses que os componentes consomem — e que mudam entre os modos claro e escuro.</p>
          <div class="grid grid-cols-1 gap-x-4">
            {[
              [
                { name: 'color-page-default',            light: '#FFFFFF', dark: '#1B1B1F' },
                { name: 'color-page-soft',               light: '#F9FAFB', dark: '#2F3033' },
                { name: 'color-surface-level-0',         light: '#FFFFFF', dark: '#2F3033' },
                { name: 'color-surface-level-1',         light: '#F9FAFB', dark: '#434349' },
                { name: 'color-surface-level-3',         light: '#EAECF0', dark: '#56565B' },
                { name: 'text-color-default',            light: '#1B1B1F', dark: '#F9FAFB' },
                { name: 'text-color-soft',               light: '#707077', dark: '#A8A8B2' },
                { name: 'text-color-disabled',           light: '#A8A8B2', dark: '#56565B' },
                { name: 'text-color-action-primary',     light: '#006EEF', dark: '#4A9DFF' },
                { name: 'text-color-action-brand',       light: '#D40000', dark: '#FF8A78' },
                { name: 'border-color-default',          light: '#DADBE3', dark: '#56565B' },
                { name: 'border-color-soft',             light: '#EAECF0', dark: '#434349' },
                { name: 'border-color-emphasis',         light: '#434349', dark: '#DADBE3' },
                { name: 'color-primary-surface-mid',     light: '#006EEF', dark: '#006EEF' },
                { name: 'color-primary-surface-soft',    light: '#EDF5FF', dark: '#001A41' },
              ],
            ].map(col => (
              <div class="space-y-1.5">
                {col.map(t => (
                  <div class="flex items-center justify-between py-1.5 border-b border-white/5 last:border-0">
                    <code class="text-[10px] text-neutral-400 font-mono truncate mr-2">{t.name}</code>
                    <div class="flex items-center gap-1 shrink-0">
                      <div class="w-3 h-3 rounded-full border border-white/10 shrink-0" style={`background:${t.light}`}></div>
                      <div class="w-3 h-3 rounded-full border border-white/10 shrink-0" style={`background:${t.dark}`}></div>
                    </div>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Diagrama de fluxo tokens -->
      <div class="py-4">
        <div class="flex items-center justify-between gap-4 mb-8">
          <div>
            <p class="text-xs font-bold tracking-widest uppercase text-neutral-400 mb-2">Fluxo de referência</p>
            <h3 class="text-2xl font-bold text-neutral-900">Da matéria-prima ao componente</h3>
          </div>
          <div class="hidden md:flex items-center gap-2 px-4 py-2 rounded-full bg-neutral-50 border border-[#EAECF0]">
            <div class="w-2 h-2 rounded-full bg-[#D40000]"></div>
            <p class="text-[11px] font-medium text-neutral-500">Base Tailwind CSS + semântica OT</p>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-4 md:gap-12">
          {[
            {
              label: 'Valor bruto',
              ex: '#006EEF',
              sub: 'Hex, px ou rem',
              iconBg: 'bg-neutral-900',
              icon: 'dot',
            },
            {
              label: 'Token primitivo',
              ex: 'colors/primary/500',
              sub: 'Escala Tailwind CSS',
              iconBg: 'bg-[#D40000]',
              icon: 'layers',
            },
            {
              label: 'Token semântico',
              ex: 'color-primary-surface-mid',
              sub: 'Intenção de uso',
              iconBg: 'bg-[#006EEF]',
              icon: 'arrow',
            },
            {
              label: 'Componente',
              ex: 'Button / primary',
              sub: 'Aplicação no produto',
              iconBg: 'bg-[#00A74E]',
              icon: 'square',
            },
          ].map((step, i) => (
            <div class="relative">
