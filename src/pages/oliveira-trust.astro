            descricao: 'Diretrizes editoriais para cada componente: quando usar, quando não usar, padrões de acessibilidade (WCAG AA) e exemplos de uso correto.',
          },
        ].map(item => (
          <div class="bg-white rounded-xl border border-[#EAECF0] p-6 group hover:shadow-sm transition-all">
            <div class="text-neutral-300 group-hover:text-[#006EEF] transition-colors mb-4" set:html={item.icon} />
            <h3 class="font-bold text-neutral-900 mb-2 text-sm group-hover:text-[#006EEF] transition-colors">{item.titulo}</h3>
            <p class="text-xs text-neutral-400 leading-relaxed">{item.descricao}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <section class="py-24" style="background:#1B1B1F">
    <div class="max-w-[1600px] mx-auto px-6">

      <div class="mb-16">
        <p class="text-xs font-bold tracking-widest uppercase text-[#D40000] mb-3">Impacto</p>
        <h2 class="text-4xl font-bold text-white leading-tight">Resultados</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-4 mb-16">
        {[
          { numero: '80+', label: 'Componentes documentados', desc: 'Prontos para uso imediato' },
          { numero: '400+', label: 'Tokens definidos', desc: 'Primitivos e semânticos' },
          { numero: '2×', label: 'Velocidade de entrega', desc: 'Menos tempo em decisões de UI' },
          { numero: '100%', label: 'Cobertura light/dark', desc: 'Nenhuma cor hard-coded' },
        ].map(r => (
          <div class="p-6 border border-white/10 rounded-2xl">
            <p class="text-4xl font-bold text-white mb-1">{r.numero}</p>
            <p class="text-sm font-semibold text-neutral-300 mb-1">{r.label}</p>
            <p class="text-xs text-neutral-500">{r.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <ContatoFooter formName="contato-ot" />


</Layout>
