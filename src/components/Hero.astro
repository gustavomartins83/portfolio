---
---

<section class="min-h-screen pt-16 flex flex-col justify-center overflow-hidden">
  <div class="max-w-[1600px] mx-auto px-6 w-full py-24">

    <div class="grid md:grid-cols-[1fr_1fr] gap-10 xl:gap-16 items-center">

      <!-- Texto -->
      <div>
        <p class="text-base text-neutral-400 mb-6 opacity-0 animate-fadein" style="animation-delay:0.05s">
          Olá, eu sou Gustavo Campos.
        </p>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-neutral-900 leading-[1] tracking-tight mb-8 opacity-0 animate-fadein" style="animation-delay:0.15s">
          Crio experiências digitais que as pessoas<br class="hidden lg:block" />
          realmente <em class="not-italic text-[#0891B2]">querem usar.</em>
        </h1>

        <p class="text-sm font-medium tracking-widest uppercase text-neutral-400 mb-12 opacity-0 animate-fadein" style="animation-delay:0.3s">
          UI/UX &nbsp;•&nbsp; Product Design &nbsp;•&nbsp; Graphic Design &nbsp;•&nbsp; Marketing
        </p>

        <div class="flex flex-wrap items-center gap-5 opacity-0 animate-fadein" style="animation-delay:0.4s">
          <a
            href="#trabalhos"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-[#0891B2] text-white text-sm font-medium rounded-full hover:bg-[#0670A0] transition-colors"
          >
            Ver trabalhos
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="#contato"
            class="text-sm font-medium text-neutral-500 hover:text-neutral-900 transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-px after:w-0 after:bg-neutral-900 after:transition-all after:duration-300 hover:after:w-full"
          >
            Vamos conversar
          </a>
        </div>
      </div>

      <!-- Ilustração linha contínua -->
      <div class="hidden md:flex items-center justify-center opacity-0 animate-fadein" style="animation-delay:0.25s">
        <svg viewBox="0 0 500 380" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">

          <!-- Fumaça -->
          <path class="steam-a" d="M168 76 C166 56 178 46 176 26 C174 8 162 0 164 -18" stroke="#1a1a1a" stroke-width="1.6" stroke-linecap="round"/>
          <path class="steam-b" d="M204 66 C202 44 216 34 214 12 C212 -10 198 -18 200 -38" stroke="#1a1a1a" stroke-width="1.6" stroke-linecap="round"/>
          <path class="steam-c" d="M240 76 C242 56 230 46 232 26 C234 8 246 0 244 -18" stroke="#1a1a1a" stroke-width="1.6" stroke-linecap="round"/>

          <!-- Rim do topo -->
          <ellipse cx="204" cy="102" rx="110" ry="18" stroke="#1a1a1a" stroke-width="1.7"/>
          <!-- Superfície interna do café -->
          <ellipse cx="204" cy="100" rx="92" ry="13" stroke="#1a1a1a" stroke-width="1.1"/>
          <!-- Crema -->
          <path d="M148 97 Q180 104 222 99 Q248 95 264 97" stroke="#1a1a1a" stroke-width="1" stroke-linecap="round" opacity="0.4"/>

          <!-- Corpo achatado — altura reduzida, lados levemente cônicos -->
          <path d="M96 106 C94 128 100 174 108 216 C114 238 128 252 148 256" stroke="#1a1a1a" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M312 106 C314 128 308 174 300 216 C294 238 280 252 260 256" stroke="#1a1a1a" stroke-width="1.8" stroke-linecap="round"/>
          <!-- Base -->
          <path d="M148 256 C154 266 172 272 204 272 C236 272 254 266 260 256" stroke="#1a1a1a" stroke-width="1.8" stroke-linecap="round"/>
          <!-- Anel da base -->
          <ellipse cx="204" cy="272" rx="56" ry="8" stroke="#1a1a1a" stroke-width="1.3"/>

          <!-- Alça direita compacta -->
          <path d="M310 148 C348 144 364 164 364 182 C364 202 348 220 310 216" stroke="#1a1a1a" stroke-width="1.7" stroke-linecap="round" fill="none"/>
          <path d="M310 168 C332 166 342 174 342 182 C342 192 332 200 310 198" stroke="#1a1a1a" stroke-width="1.1" stroke-linecap="round" fill="none" opacity="0.4"/>

          <!-- Linha de base -->
          <line x1="20" y1="280" x2="490" y2="280" stroke="#1a1a1a" stroke-width="1.5" stroke-linecap="round"/>

          <!-- Grãos — 10 ao total, espalhados à direita e à esquerda -->
          <g transform="rotate(-14 354 268)"><ellipse cx="354" cy="268" rx="16" ry="9" stroke="#1a1a1a" stroke-width="1.4"/><path d="M345 268 Q354 272 363 268" stroke="#1a1a1a" stroke-width="1" stroke-linecap="round" opacity="0.5"/></g>
          <g transform="rotate(10 390 264)"><ellipse cx="390" cy="264" rx="16" ry="9" stroke="#1a1a1a" stroke-width="1.4"/><path d="M381 264 Q390 268 399 264" stroke="#1a1a1a" stroke-width="1" stroke-linecap="round" opacity="0.5"/></g>
          <g transform="rotate(-5 426 270)"><ellipse cx="426" cy="270" rx="15" ry="9" stroke="#1a1a1a" stroke-width="1.4"/><path d="M417 270 Q426 274 435 270" stroke="#1a1a1a" stroke-width="1" stroke-linecap="round" opacity="0.5"/></g>
          <g transform="rotate(16 458 266)"><ellipse cx="458" cy="266" rx="14" ry="8" stroke="#1a1a1a" stroke-width="1.3"/><path d="M450 266 Q458 270 466 266" stroke="#1a1a1a" stroke-width="0.9" stroke-linecap="round" opacity="0.45"/></g>
          <g transform="rotate(20 370 250)"><ellipse cx="370" cy="250" rx="12" ry="7" stroke="#1a1a1a" stroke-width="1.2"/><path d="M363 250 Q370 253 377 250" stroke="#1a1a1a" stroke-width="0.9" stroke-linecap="round" opacity="0.45"/></g>
          <g transform="rotate(-18 406 248)"><ellipse cx="406" cy="248" rx="12" ry="7" stroke="#1a1a1a" stroke-width="1.2"/><path d="M399 248 Q406 251 413 248" stroke="#1a1a1a" stroke-width="0.9" stroke-linecap="round" opacity="0.45"/></g>
          <g transform="rotate(-8 442 252)"><ellipse cx="442" cy="252" rx="12" ry="7" stroke="#1a1a1a" stroke-width="1.2"/><path d="M435 252 Q442 255 449 252" stroke="#1a1a1a" stroke-width="0.9" stroke-linecap="round" opacity="0.45"/></g>
          <g transform="rotate(6 56 272)"><ellipse cx="56" cy="272" rx="14" ry="8" stroke="#1a1a1a" stroke-width="1.3"/><path d="M49 272 Q56 275 63 272" stroke="#1a1a1a" stroke-width="0.9" stroke-linecap="round" opacity="0.45"/></g>
          <g transform="rotate(-12 84 256)"><ellipse cx="84" cy="256" rx="12" ry="7" stroke="#1a1a1a" stroke-width="1.2"/><path d="M77 256 Q84 259 91 256" stroke="#1a1a1a" stroke-width="0.9" stroke-linecap="round" opacity="0.45"/></g>
          <g transform="rotate(15 46 254)"><ellipse cx="46" cy="254" rx="11" ry="6" stroke="#1a1a1a" stroke-width="1.1"/><path d="M40 254 Q46 257 52 254" stroke="#1a1a1a" stroke-width="0.8" stroke-linecap="round" opacity="0.4"/></g>

        </svg>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes fadein {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fadein {
    animation: fadein 0.6s ease forwards;
  }

  @keyframes steam-rise {
    0%   { opacity: 0; transform: translateY(4px); }
    20%  { opacity: 0.9; }
    80%  { opacity: 0.3; }
    100% { opacity: 0; transform: translateY(-10px); }
  }
  .steam-a { animation: steam-rise 3s ease-in-out infinite; animation-delay: 0s; }
  .steam-b { animation: steam-rise 3s ease-in-out infinite; animation-delay: 1s; }
  .steam-c { animation: steam-rise 3s ease-in-out infinite; animation-delay: 2s; }
</style>
