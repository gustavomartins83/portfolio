---
const tokens = [
  { label: 'Accent', value: '#0891B2', bg: '#0891B2' },
  { label: 'Text', value: '#171717', bg: '#171717' },
  { label: 'Muted', value: '#737373', bg: '#737373' },
  { label: 'Surface', value: '#FAFAFA', bg: '#FAFAFA' },
  { label: 'Border', value: '#E5E5E5', bg: '#E5E5E5' },
]

const typefaces = [
  { peso: 'Regular 400', amostra: 'Aa', weight: 400 },
  { peso: 'Semibold 600', amostra: 'Aa', weight: 600 },
  { peso: 'Bold 700', amostra: 'Aa', weight: 700 },
]

const radii = ['4px', '8px', '12px', '16px', '999px']
---

<section id="contato" class="bg-neutral-900 py-32">
  <div class="max-w-[1600px] mx-auto px-6">

    <!-- Label fora do grid -->
    <p class="text-sm font-medium tracking-widest uppercase text-[#0891B2] mb-6">
      Contato
    </p>

    <!-- Heading + Formulário lado a lado -->
    <div class="grid md:grid-cols-2 gap-16 items-start mb-24 pb-24 border-b border-white/10">

      <!-- Esquerda: título + links -->
      <div class="flex flex-col justify-between gap-12">
        <div>
          <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1] tracking-tight mb-8">
            Tem um projeto<br />
            que merece<br />
            <em class="not-italic text-[#0891B2]">bom design?</em>
          </h2>
          <p class="text-base text-neutral-500 leading-relaxed">
            Aceito um número limitado de projetos por trimestre. Se você tem um produto, plataforma ou desafio de design — vamos conversar.
          </p>
        </div>

        <div class="space-y-4">
          <a
            href="mailto:gustavomartins.rio2012@gmail.com"
            class="flex items-center gap-2 text-sm font-semibold text-white hover:text-[#0891B2] transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-px after:w-0 after:bg-[#0891B2] after:transition-all after:duration-300 hover:after:w-full w-fit"
          >
            gustavomartins.rio2012@gmail.com
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 13L13 3M13 3H6M13 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/gustavocamposdesign"
            target="_blank" rel="noopener"
            class="flex items-center gap-2 text-sm font-semibold text-white hover:text-[#0891B2] transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-px after:w-0 after:bg-[#0891B2] after:transition-all after:duration-300 hover:after:w-full w-fit"
          >
            linkedin.com/in/gustavocamposdesign
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 13L13 3M13 3H6M13 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="flex flex-wrap gap-4 pt-2">
            <a href="https://www.behance.net/gustavocamposdesign" target="_blank" rel="noopener"
              class="text-sm text-neutral-600 hover:text-white transition-colors">Behance</a>
            <span class="text-neutral-700">·</span>
            <a href="https://www.instagram.com/" target="_blank" rel="noopener"
              class="text-sm text-neutral-600 hover:text-white transition-colors">Instagram</a>
          </div>
        </div>
      </div>

      <!-- Direita: formulário -->
      <form name="contato" method="POST" data-netlify="true" class="space-y-4 self-start">
        <input type="hidden" name="form-name" value="contato" />
        <div>
          <label class="block text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-2" for="nome">Nome</label>
          <input
            id="nome" name="nome" type="text" required placeholder="Seu nome"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder:text-neutral-600 focus:outline-none focus:border-[#0891B2] transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-2" for="email">E-mail</label>
          <input
            id="email" name="email" type="email" required placeholder="seu@email.com"
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder:text-neutral-600 focus:outline-none focus:border-[#0891B2] transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-2" for="mensagem">Mensagem</label>
          <textarea
            id="mensagem" name="mensagem" required rows="6"
            placeholder="Conte um pouco sobre o projeto ou oportunidade..."
            class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder:text-neutral-600 focus:outline-none focus:border-[#0891B2] transition-colors resize-none"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full py-4 bg-[#0891B2] text-white text-sm font-medium rounded-xl hover:bg-[#0670A0] transition-colors"
        >
          Enviar mensagem →
        </button>
      </form>
    </div>

    <!-- Design System -->
    <div>
      <div class="flex items-baseline justify-between mb-8">
        <p class="text-xs font-semibold tracking-widest uppercase text-neutral-600">
          Design System <span class="font-normal text-neutral-700 ml-1">v1.0</span>
        </p>
        <span class="text-xs text-neutral-700">Tokens, tipografia, primitivos</span>
      </div>

      <div class="grid md:grid-cols-3 gap-4">

        <!-- Cores -->
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-5">Cores</p>
          <div class="space-y-3">
            {tokens.map(token => (
              <div class="flex items-center gap-3">
                <span class="w-5 h-5 rounded-md border border-white/10 shrink-0" style={`background:${token.bg}`}></span>
                <span class="text-xs font-medium text-neutral-400 flex-1">{token.label}</span>
                <span class="text-xs font-mono text-neutral-600">{token.value}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Tipografia -->
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10">
          <p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-5">Tipografia</p>
          <div class="space-y-5">
            {typefaces.map(t => (
              <div class="flex items-baseline justify-between">
                <span class="text-3xl text-white/80" style={`font-weight:${t.weight}`}>{t.amostra}</span>
                <div class="text-right">
                  <p class="text-xs font-semibold text-neutral-400">Inter</p>
                  <p class="text-xs text-neutral-600">{t.peso}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Raios + Motion -->
        <div class="bg-white/5 rounded-2xl p-6 border border-white/10 flex flex-col gap-8">
          <div>
            <p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-5">Raios</p>
            <div class="flex items-end gap-3">
              {radii.map(r => (
                <div class="flex flex-col items-center gap-2">
                  <div class="w-7 h-7 bg-[#0891B2] border border-[#0891B2]/30" style={`border-radius:${r}`}></div>
                  <span class="text-[9px] text-neutral-600 font-mono">{r}</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-4">Motion</p>
            <div class="space-y-2">
              <div class="flex items-center justify-between">
                <span class="text-xs text-neutral-500">Duração</span>
                <span class="text-xs font-mono text-neutral-600">300ms · 500ms</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-xs text-neutral-500">Easing</span>
                <span class="text-xs font-mono text-neutral-600">ease-out</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-xs text-neutral-500">Scroll</span>
                <span class="text-xs font-mono text-neutral-600">Lenis 1.2s</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
