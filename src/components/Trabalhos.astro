---
const projetos = [
  {
    numero: '01',
    empresa: 'Oliveira Trust',
    titulo: 'Design System',
    descricao: 'Sistema de design para plataforma fintech com tokens, componentes e documentação para times distribuídos.',
    tags: ['Design System', 'Fintech', 'Figma'],
    resultado: 'Sistema escalável',
    bg: 'bg-neutral-900',
    cor: 'text-white',
    large: true,
    url: `${import.meta.env.BASE_URL}oliveira-trust`,
    thumb: 'ot',
  },
  {
    numero: '02',
    empresa: 'Petz',
    titulo: 'Clubz',
    descricao: 'Programa de benefícios com quatro níveis — Bronze, Prata, Ouro e Diamante — integrado ao super app.',
    tags: ['Discovery', 'UX/UI Design', 'End-to-End'],
    resultado: 'Clube líder do setor',
    bg: 'bg-[#0B2743]',
    cor: 'text-white',
    large: false,
    url: `${import.meta.env.BASE_URL}petz-clubz`,
    thumb: 'thumb_clubz',
  },
  {
    numero: '03',
    empresa: 'Petz',
    titulo: 'Super App',
    descricao: 'Redesign completo do super app unificando compras, agendamentos, planos de saúde pet e o Clubz em uma única experiência.',
    tags: ['UX Research', 'UI Design', 'Super App'],
    resultado: '4.8★ App Store',
    bg: 'bg-neutral-900',
    cor: 'text-white',
    large: true,
  },
  {
    numero: '04',
    empresa: 'Funcional Health Tech',
    titulo: 'App Multi',
    descricao: 'App para o cartão corporativo Mastercard de benefícios — alimentação, mobilidade, prêmios e mais.',
    tags: ['Mobile', 'Benefícios', 'iOS & Android'],
    resultado: '4M+ estabelecimentos',
    bg: 'bg-neutral-100',
    cor: 'text-neutral-900',
    large: false,
  },
  {
    numero: '05',
    empresa: 'Izenu',
    titulo: 'App',
    descricao: 'Plataforma de streaming musical e rede social para países lusófonos — conectando artistas e fãs da CPLP.',
    tags: ['UI Design', 'Streaming', 'Social'],
    resultado: 'Lançado na CPLP',
    bg: 'bg-neutral-800',
    cor: 'text-white',
    large: false,
  },
  {
    numero: '06',
    empresa: 'Badesul',
    titulo: 'Internet Banking',
    descricao: 'Nova interface do internet banking do Badesul — simplificando operações com foco em acessibilidade e confiança.',
    tags: ['UI Design', 'Banking', 'Web'],
    resultado: 'Banco de fomento RS',
    bg: 'bg-[#0891B2]',
    cor: 'text-white',
    large: true,
  },
  {
    numero: '07',
    empresa: 'Ypê',
    titulo: 'App',
    descricao: 'Aplicativo de fidelidade com missões, sorteios, lista de compras e a assistente virtual Yara com IA generativa.',
    tags: ['Mobile', 'Loyalty', 'UX'],
    resultado: 'Top limpeza App Store',
    bg: 'bg-neutral-50',
    cor: 'text-neutral-900',
    large: true,
  },
]

const colEsq = [projetos[0], projetos[2], projetos[4], projetos[6]]
const colDir  = [projetos[1], projetos[3], projetos[5]]

const alturas = {
  '01': '520px',
  '02': '480px',
  '03': '560px',
  '04': '580px',
  '05': '320px',
  '06': '380px',
  '07': '480px',
} as Record<string, string>

---

<section id="trabalhos" class="pt-[72px] pb-24 md:py-24">
  <div class="max-w-[1600px] mx-auto px-6">

    <div class="flex items-end justify-between mb-16">
      <div>
        <p data-reveal class="text-sm font-medium tracking-widest uppercase text-[#0891B2] mb-3">
          Trabalhos
        </p>
        <h2 data-reveal data-delay="80" class="text-4xl md:text-5xl font-bold text-neutral-900 leading-tight">
          Projetos<br />selecionados
        </h2>
      </div>
      <p data-reveal data-delay="160" class="hidden md:block text-sm text-neutral-400 max-w-xs text-right leading-relaxed">
        Cada projeto reflete um problema real resolvido com estratégia, pesquisa e execução.
      </p>
    </div>

    <div class="flex flex-col gap-4 md:hidden">
      {projetos.map((projeto, i) => (
        <article
          data-reveal
          data-delay={i * 90}
          class={`group relative ${projeto.bg} rounded-2xl overflow-hidden cursor-pointer`}
          style="height:360px"
          onclick={projeto.url ? `window.location.href='${projeto.url}'` : undefined}
        >
          {projeto.thumb === 'ot' && (
            <div class="absolute inset-0 pointer-events-none select-none overflow-hidden rounded-2xl" style="isolation:isolate" aria-hidden="true">
              <div class="ot-hero-thumb">
                <div class="ot-hero-thumb__tiles">
                  {Array.from({ length: 72 }).map((_, i) => (
                    <span style={`opacity:${0.18 + (i % 7) * 0.09}`}></span>
                  ))}
                </div>

                <div class="ot-hero-thumb__cover">
                  <div class="ot-hero-thumb__cover-copy">
                    <span>Design System · Oliveira Trust</span>
                    <strong>OT.DS</strong>
                  </div>
                </div>

              </div>

              <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(12,12,14,0.68) 0%,rgba(12,12,14,0.18) 34%,transparent 62%)"></div>
              <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(40,0,0,0.36) 0%,transparent 42%)"></div>
            </div>
          )}

          {projeto.thumb === 'thumb_clubz' && (
            <div class="absolute inset-0 pointer-events-none select-none overflow-hidden rounded-2xl" aria-hidden="true">
              {/* Moedas exportadas do Figma em 3× — transparência real */}
              <img
                src={`${import.meta.env.BASE_URL}thumb_clubz.png`}
                alt=""
                class="clubz-thumb__moedas"
              />

              {/* Fade inferior em azul Clubz */}
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(11,39,67,1) 0%, rgba(11,39,67,0.60) 18%, transparent 38%);"></div>
            </div>
          )}

          <div class="relative flex flex-col justify-between p-8 md:p-10 h-full" style={`min-height: inherit`}>

            {/* Topo */}
            <div class="flex items-start justify-between">
              <span class={`text-xs font-bold tracking-widest ${projeto.cor} opacity-30`}>
                {projeto.numero}
              </span>
            </div>

            {/* Base */}
            <div>
              <p class={`text-xs font-semibold tracking-widest uppercase mb-2 ${projeto.cor} opacity-50`}>
                {projeto.empresa}
              </p>
              <h3 class={`font-bold mb-5 leading-tight group-hover:opacity-70 transition-opacity ${projeto.cor} ${projeto.large ? 'text-2xl md:text-4xl' : 'text-xl md:text-2xl'}`}>
                {projeto.titulo}
              </h3>
              <div class="flex items-center justify-between gap-4">
                <div class="flex flex-wrap gap-2">
                  {projeto.tags.map(tag => (
                    <span class={`text-xs font-medium px-3 py-1 rounded-full border ${projeto.cor} opacity-50 border-current`}>
                      {tag}
                    </span>
                  ))}
                </div>
                <div class={`w-9 h-9 rounded-full border ${projeto.cor} border-current opacity-30 group-hover:opacity-80 transition-all flex items-center justify-center shrink-0`}>
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class={projeto.cor}>
                    <path d="M3 13L13 3M13 3H6M13 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </div>

          </div>
        </article>
      ))}
    </div>

    <div class="hidden md:grid md:grid-cols-2 gap-4 items-start">
      {[colEsq, colDir].map((col) => (
        <div class="flex flex-col gap-4">
          {col.map((projeto, i) => (
            <article
              data-reveal
              data-delay={i * 90}
              class={`group relative ${projeto.bg} rounded-2xl overflow-hidden cursor-pointer`}
              style={`height:${alturas[projeto.numero] ?? '400px'}`}
              onclick={projeto.url ? `window.location.href='${projeto.url}'` : undefined}
            >
              {projeto.thumb === 'ot' && (
                <div class="absolute inset-0 pointer-events-none select-none overflow-hidden rounded-2xl" style="isolation:isolate" aria-hidden="true">
                  <div class="ot-hero-thumb">
                    <div class="ot-hero-thumb__tiles">
                      {Array.from({ length: 72 }).map((_, i) => (
                        <span style={`opacity:${0.18 + (i % 7) * 0.09}`}></span>
                      ))}
                    </div>

                    <div class="ot-hero-thumb__cover">
                      <div class="ot-hero-thumb__cover-copy">
                        <span>Design System · Oliveira Trust</span>
                        <strong>OT.DS</strong>
                      </div>
                    </div>

                  </div>

                  <div class="absolute inset-0" style="background:linear-gradient(to top,rgba(12,12,14,0.68) 0%,rgba(12,12,14,0.18) 34%,transparent 62%)"></div>
                  <div class="absolute inset-0" style="background:linear-gradient(to right,rgba(40,0,0,0.36) 0%,transparent 42%)"></div>
                </div>
              )}

              {projeto.thumb === 'thumb_clubz' && (
                <div class="absolute inset-0 pointer-events-none select-none overflow-hidden rounded-2xl" aria-hidden="true">
                  {/* Moedas exportadas do Figma em 3× — transparência real */}
                  <img
                    src={`${import.meta.env.BASE_URL}thumb_clubz.png`}
                    alt=""
                    class="clubz-thumb__moedas"
                  />

                  {/* Fade inferior em azul Clubz */}
                  <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(11,39,67,1) 0%, rgba(11,39,67,0.60) 18%, transparent 38%);"></div>
                </div>
              )}

              <div class="relative flex flex-col justify-between p-8 md:p-10 h-full" style={`min-height: inherit`}>

                {/* Topo */}
                <div class="flex items-start justify-between">
                  <span class={`text-xs font-bold tracking-widest ${projeto.cor} opacity-30`}>
                    {projeto.numero}
                  </span>
                </div>

                {/* Base */}
                <div>
                  <p class={`text-xs font-semibold tracking-widest uppercase mb-2 ${projeto.cor} opacity-50`}>
                    {projeto.empresa}
                  </p>
                  <h3 class={`font-bold mb-5 leading-tight group-hover:opacity-70 transition-opacity ${projeto.cor} ${projeto.large ? 'text-2xl md:text-4xl' : 'text-xl md:text-2xl'}`}>
                    {projeto.titulo}
                  </h3>
                  <div class="flex items-center justify-between gap-4">
                    <div class="flex flex-wrap gap-2">
                      {projeto.tags.map(tag => (
                        <span class={`text-xs font-medium px-3 py-1 rounded-full border ${projeto.cor} opacity-50 border-current`}>
                          {tag}
                        </span>
                      ))}
                    </div>
                    <div class={`w-9 h-9 rounded-full border ${projeto.cor} border-current opacity-30 group-hover:opacity-80 transition-all flex items-center justify-center shrink-0`}>
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class={projeto.cor}>
                        <path d="M3 13L13 3M13 3H6M13 3v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </div>
                </div>

              </div>
            </article>
          ))}

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .ot-hero-thumb {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 82% 12%, rgba(255, 255, 255, 0.22), transparent 28%),
      linear-gradient(135deg, #280000 0%, #7a0000 48%, #d40000 100%);
  }

  .ot-hero-thumb::before {
    content: "";
    position: absolute;
    inset: -18% -10% auto auto;
    width: 54%;
    height: 54%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.16);
    filter: blur(44px);
  }

  .ot-hero-thumb__tiles {
    position: absolute;
    inset: 20px 24px 24px;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    grid-template-rows: repeat(6, 62px);
    gap: 8px;
    opacity: 1;
  }

  .ot-hero-thumb__tiles span {
    display: block;
    min-width: 0;
    min-height: 0;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }

  .ot-hero-thumb__cover {
    position: absolute;
    z-index: 3;
    left: 50%;
    top: 34%;
    width: 70%;
    aspect-ratio: 16 / 5;
    overflow: hidden;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow: 0 28px 70px rgba(40, 0, 0, 0.36);
    transform: translate(-50%, -50%);
  }

  .ot-hero-thumb__cover-copy {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .ot-hero-thumb__cover-copy span {
    color: rgba(255, 255, 255, 0.6);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ot-hero-thumb__cover-copy strong {
    color: rgba(255, 255, 255, 0.26);
    font-size: 64px;
    line-height: 1;
    letter-spacing: -0.06em;
  }

  @media (max-width: 767px) {
    .ot-hero-thumb__cover {
      width: 78%;
      top: 42%;
      border-radius: 14px;
    }

    .ot-hero-thumb__cover-copy span {
      font-size: 8px;
    }

    .ot-hero-thumb__cover-copy strong {
      font-size: 44px;
    }
  }

  /* ── Clubz thumb ────────────────────────────────────── */
  .clubz-thumb__moedas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
    transform-origin: center 40%;
    filter: saturate(1.1) brightness(1.04);
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  article:hover .clubz-thumb__moedas {
    transform: scale(1.07);
  }

  /* ── OT thumb zoom ──────────────────────────────────── */
  .ot-hero-thumb {
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform-origin: center center;
  }

  article:hover .ot-hero-thumb {
    transform: scale(1.06);
  }


</style>
