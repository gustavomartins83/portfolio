---
const { formName = 'contato-projeto' } = Astro.props
---

<section id="contato" class="py-20 bg-neutral-900">
  <div class="max-w-[1600px] mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-center gap-10">
      <div data-reveal class="md:w-80 shrink-0">
        <h2 class="text-3xl font-bold text-white leading-snug mb-4">
          Tem um projeto que<br />merece <em class="not-italic text-[#0891B2]">bom design?</em>
        </h2>
        <p class="text-base text-neutral-500 leading-relaxed">Aceito projetos selecionados por trimestre. Vamos conversar.</p>
      </div>
      <form data-reveal data-delay="140" name={formName} method="POST" data-netlify="true" class="flex flex-col gap-3 md:w-96 w-full">
        <input type="hidden" name="form-name" value={formName} />
        <div class="grid grid-cols-2 gap-3">
          <input name="nome" type="text" required placeholder="Nome"
            class="px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder:text-neutral-600 focus:outline-none focus:border-[#0891B2] transition-colors" />
          <input name="email" type="email" required placeholder="E-mail"
            class="px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder:text-neutral-600 focus:outline-none focus:border-[#0891B2] transition-colors" />
        </div>
        <textarea name="mensagem" required rows="3"
          placeholder="Conte sobre o projeto..."
          class="px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder:text-neutral-600 focus:outline-none focus:border-[#0891B2] transition-colors resize-none"></textarea>
        <button type="submit"
          class="py-3 bg-[#0891B2] text-white text-sm font-medium rounded-lg hover:bg-[#0670A0] transition-colors">
          Enviar mensagem →
        </button>
      </form>
    </div>
  </div>
</section>
